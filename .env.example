# Agent Knowledge System - Environment Configuration
# All configuration is OPTIONAL
#
# Setup (if needed):
# 1. Copy this file: cp .env.example .env
# 2. Fill in your tokens below
# 3. The .env file is in .gitignore and will not be committed

# ============================================================
# GitHub Personal Access Token (Optional)
# ============================================================
# Create one at: https://github.com/settings/tokens
# Required scopes: repo, read:org
# Benefits: 5,000 req/hour vs 60 without token, access to private repos
# GH_API_TOKEN=ghp_your_token_here

# ============================================================
# JIRA Configuration (Optional - only for private instances)
# ============================================================
# For public JIRA (issues.redhat.com), no authentication is needed
# JIRA_URL=https://your-jira.com
# JIRA_EMAIL=your-email@company.com
# JIRA_API_TOKEN=your-jira-token
